# XRPL network selector: "testnet" (default), "devnet", or "mainnet"
XRPL_NETWORK=testnet

# Demo seller wallet (run `pnpm setup:wallets` and paste the output)
SELLER_SEED=
SELLER_ADDRESS=

# Demo buyer wallet
BUYER_SEED=
BUYER_ADDRESS=

# Optional: override the SQLite DB path. Defaults to ./data/flowback.db
# FLOWBACK_DB_PATH=

# Optional: override the XRPL WebSocket endpoint
# XRPL_ENDPOINT=wss://s.altnet.rippletest.net:51233
